# ===========================================
# Talent Intelligence Platform Configuration
# ===========================================
# Copy this file to .env.local and fill in your values

# -------------------------------------------
# LLM Provider Selection
# -------------------------------------------
# Options: groq (FREE), deepseek (CHEAP), openai (PAID)
LLM_PROVIDER=groq

# -------------------------------------------
# Groq Configuration (FREE - Default)
# -------------------------------------------
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768

# -------------------------------------------
# DeepSeek Configuration (Very Cheap - ~$0.14/1M tokens)
# -------------------------------------------
# Get your API key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# Options: deepseek-chat (V3), deepseek-reasoner (R1)

# -------------------------------------------
# OpenAI Configuration (Paid)
# -------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
# Options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo, gpt-4o, gpt-4o-mini

# -------------------------------------------
# CData Connect AI Configuration
# -------------------------------------------
# MCP Endpoint URL
CDATA_MCP_ENDPOINT=https://mcp.cloud.cdata.com/mcp

# Authentication (email:PAT format)
# Get your PAT from: https://cloud.cdata.com/settings/tokens
CDATA_EMAIL=your-email@company.com
CDATA_PAT=your-personal-access-token-here

# Or use combined format (will be base64 encoded for Basic Auth)
# CDATA_AUTH=your-email@company.com:your-pat-here

# Workspace ID (optional, for multi-workspace setups)
CDATA_WORKSPACE_ID=

# -------------------------------------------
# Google Sheets Data Source
# -------------------------------------------
# The spreadsheet ID from your Google Sheets URL
# Example: https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEETS_ID=1ioXbGPzS-DqqpkAYXDmGpJx8-N81e5H5dj6yk-pqVWY

# Sheet/Table names (comma-separated)
GOOGLE_SHEETS_TABLES=Candidates,JobRequisitions,Placements,Clients,Activities,SkillTaxonomy

# -------------------------------------------
# Token Usage Limits
# -------------------------------------------
DAILY_TOKEN_LIMIT=100000
WARN_TOKEN_THRESHOLD=80000

# -------------------------------------------
# Feature Flags
# -------------------------------------------
ENABLE_WRITE_OPERATIONS=false
ENABLE_SQL_PREVIEW=true
ENABLE_ACTIVITY_LOGGING=true

# -------------------------------------------
# App Settings
# -------------------------------------------
NEXT_PUBLIC_APP_NAME=Talent Intelligence Platform
NEXT_PUBLIC_APP_VERSION=2.0.0
